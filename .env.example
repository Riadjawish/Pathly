# Docker Compose
POSTGRES_DB=pathly
POSTGRES_USER=pathly
POSTGRES_PASSWORD=change-this-development-password
POSTGRES_PORT=5432
API_PORT=8000
WEB_PORT=3000

# Application
APP_NAME=Pathly API
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+asyncpg://pathly:change-this-development-password@localhost:5432/pathly
DATABASE_ECHO=false
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Authentication
# Generate with: openssl rand -hex 32
SECRET_KEY=replace-with-a-random-secret-at-least-32-characters-long
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ALGORITHM=HS256
JWT_ISSUER=pathly-api
JWT_AUDIENCE=pathly-web
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# Used to build links in password-reset/verification emails
FRONTEND_BASE_URL=http://localhost:3000

# Google Gemini
GEMINI_API_KEY=
GEMINI_GENERATION_MODEL=gemini-3.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-2

# Files and vector index
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./data/uploads
MAX_UPLOAD_SIZE_MB=25
CHROMA_PATH=./data/chroma

# Browser-facing URL. This must be reachable by the browser, not only by Docker.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

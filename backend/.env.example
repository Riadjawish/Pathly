APP_NAME=Pathly API
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# PostgreSQL (async SQLAlchemy driver)
DATABASE_URL=postgresql+asyncpg://pathly:pathly@localhost:5432/pathly
DATABASE_ECHO=false

# Replace this with a long random value before sharing or deploying the app.
SECRET_KEY=replace-with-at-least-32-random-characters
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ALGORITHM=HS256
JWT_ISSUER=pathly-api
JWT_AUDIENCE=pathly-web

# Google Identity Services OAuth client used by the web app.
GOOGLE_CLIENT_ID=

# Gemini is optional at boot and required for AI generation/RAG endpoints.
GEMINI_API_KEY=
GEMINI_GENERATION_MODEL=gemini-3.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_EMBEDDING_DIMENSIONS=768
GEMINI_RETRY_ATTEMPTS=3

# Local in development; the service boundary allows an S3 implementation later.
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./data/uploads
CHROMA_PATH=./data/chroma
CHROMA_COLLECTION=pathly-chunks
MAX_UPLOAD_SIZE_MB=25

# Pydantic reads this as JSON.
CORS_ORIGINS=["http://localhost:3000"]
